# Core runtime
APP_BASE_URL=https://your-frontend-domain.example
FRONTEND_ORIGIN=https://your-frontend-domain.example
EXTRA_FRONTEND_ORIGINS=
PORT=8000
RUN_DB_MIGRATIONS_ON_START=true

# Persistence
DATABASE_URL=postgresql://user:password@host:5432/database
SQLITE_DATABASE_PATH=data/retriever.db
CACHE_BACKEND=redis
REDIS_URL=redis://default:password@host:6379/0
REDIS_PREFIX=signalscope

# AI providers
GEMINI_API_KEY=
OPENAI_API_KEY=
NEWSAPI_KEY=
STRICT_REAL_EMBEDDINGS=false
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=signalscope_docs
VECTOR_BACKEND=qdrant
VECTOR_TOP_K=120

# Email / auth flows
EMAIL_PREVIEW_TOKENS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=SignalScope AI
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Performance / observability
QUERY_CACHE_MINUTES=20
RATE_LIMIT_PER_MINUTE=90
LOG_LEVEL=INFO
ENABLE_METRICS=true
