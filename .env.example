# ============================================================================
# SignalScope AI — Development Environment Template
# Copy to .env and fill in with your values
# ============================================================================

# ── API Keys (optional for local development) ───────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
NEWSAPI_KEY=

# ── Database ────────────────────────────────────────────────────────────────
# Postgres (for docker-compose; leave empty to use SQLite locally)
POSTGRES_DB=signalscope
POSTGRES_USER=signalscope
POSTGRES_PASSWORD=signalscope
DATABASE_URL=postgresql://signalscope:signalscope@postgres:5432/signalscope

# SQLite (used by default when DATABASE_URL is not postgresql)
SQLITE_DATABASE_PATH=data/retriever.db
RUN_DB_MIGRATIONS_ON_START=true

# ── Cache (Redis) ───────────────────────────────────────────────────────────
CACHE_BACKEND=redis
REDIS_URL=redis://redis:6379/0
REDIS_PREFIX=signalscope
QUERY_CACHE_MINUTES=20

# ── Frontend URLs ───────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
EXTRA_FRONTEND_ORIGINS=http://127.0.0.1:3000

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8000
WEB_CONCURRENCY=4

# ── Embeddings & Vector Search ──────────────────────────────────────────────
STRICT_REAL_EMBEDDINGS=false
EMBEDDING_MODEL=text-embedding-3-small
EXPLANATION_MODEL=gpt-4-1-mini
VECTOR_BACKEND=qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=signalscope_docs
VECTOR_TOP_K=120

# ── Email / SMTP (optional) ────────────────────────────────────────────────
EMAIL_PREVIEW_TOKENS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=SignalScope AI
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=90

# ── Logging ────────────────────────────────────────────────────────────────
LOG_FORMAT=text
LOG_LEVEL=INFO
ENABLE_METRICS=true
